{
  "version": 2,
  "builds": [
    { "src": "api/indicators.js", "use": "@vercel/node" },
    { "src": "api/insight.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/indicators", "dest": "/api/indicators.js" },
    { "src": "/api/insight", "dest": "/api/insight.js" },
    { "src": "/", "dest": "/index.html" }
  ]
}